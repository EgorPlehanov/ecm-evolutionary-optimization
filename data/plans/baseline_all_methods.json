{
  "format": "ecm_run_plan_v1",
  "description": "Тюнинг после первого полного прогона: суженное окно B1/B2 + увеличенные бюджеты optimize/validate для de/rs/pso/bo/ga",
  "operations": [
    {
      "type": "generate",
      "label": "dataset_main",
      "args": {
        "target-digits": 20,
        "cofactor-digits": 30,
        "train-count": 8,
        "control-count": 8,
        "seed": 42
      }
    },
    {
      "type": "optimize",
      "label": "opt_de",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "de",
        "de-popsize": 8,
        "de-maxiter": 6,
        "curves-per-n": 10,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 200000,
        "b2-min": 1000,
        "b2-max": 5000000,
        "ratio-max": 60
      }
    },
    {
      "type": "validate",
      "label": "val_de",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_de.result_file"
        },
        "curves-per-n": 20,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_rs",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "rs",
        "rs-budget": 45,
        "curves-per-n": 10,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 200000,
        "b2-min": 1000,
        "b2-max": 5000000,
        "ratio-max": 60
      }
    },
    {
      "type": "validate",
      "label": "val_rs",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_rs.result_file"
        },
        "curves-per-n": 20,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_pso",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "pso",
        "pso-swarm-size": 14,
        "pso-iterations": 8,
        "curves-per-n": 10,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 200000,
        "b2-min": 1000,
        "b2-max": 5000000,
        "ratio-max": 60
      }
    },
    {
      "type": "validate",
      "label": "val_pso",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_pso.result_file"
        },
        "curves-per-n": 20,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_bo",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "bo",
        "bo-initial-samples": 10,
        "bo-iterations": 14,
        "bo-candidate-pool": 1200,
        "curves-per-n": 10,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 200000,
        "b2-min": 1000,
        "b2-max": 5000000,
        "ratio-max": 60
      }
    },
    {
      "type": "validate",
      "label": "val_bo",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_bo.result_file"
        },
        "curves-per-n": 20,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_ga",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "ga",
        "ga-population-size": 16,
        "ga-generations": 10,
        "ga-mutation-prob": 0.18,
        "curves-per-n": 10,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 200000,
        "b2-min": 1000,
        "b2-max": 5000000,
        "ratio-max": 60
      }
    },
    {
      "type": "validate",
      "label": "val_ga",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_ga.result_file"
        },
        "curves-per-n": 20,
        "curve-timeout-sec": 5
      }
    }
  ]
}