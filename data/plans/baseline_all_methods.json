{
  "format": "ecm_run_plan_v1",
  "description": "Тюнинг после трёх полных прогонов для target-digits=20: фокус на RS/GA/PSO, суженное окно B1/B2 и BO в режиме sanity-check",
  "operations": [
    {
      "type": "generate",
      "label": "dataset_main",
      "args": {
        "target-digits": 20,
        "cofactor-digits": 30,
        "train-count": 20,
        "control-count": 20,
        "seed": 42
      }
    },
    {
      "type": "optimize",
      "label": "opt_de",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "de",
        "de-popsize": 10,
        "de-maxiter": 8,
        "curves-per-n": 12,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 12000,
        "b2-min": 1000,
        "b2-max": 144000,
        "ratio-max": 12
      }
    },
    {
      "type": "validate",
      "label": "val_de",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_de.result_file"
        },
        "curves-per-n": 24,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_rs",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "rs",
        "rs-budget": 80,
        "curves-per-n": 12,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 12000,
        "b2-min": 1000,
        "b2-max": 144000,
        "ratio-max": 12
      }
    },
    {
      "type": "validate",
      "label": "val_rs",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_rs.result_file"
        },
        "curves-per-n": 24,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_pso",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "pso",
        "pso-swarm-size": 20,
        "pso-iterations": 14,
        "curves-per-n": 12,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 12000,
        "b2-min": 1000,
        "b2-max": 144000,
        "ratio-max": 12
      }
    },
    {
      "type": "validate",
      "label": "val_pso",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_pso.result_file"
        },
        "curves-per-n": 24,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_bo",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "bo",
        "bo-initial-samples": 10,
        "bo-iterations": 10,
        "bo-candidate-pool": 1000,
        "curves-per-n": 12,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 12000,
        "b2-min": 1000,
        "b2-max": 144000,
        "ratio-max": 12
      }
    },
    {
      "type": "validate",
      "label": "val_bo",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_bo.result_file"
        },
        "curves-per-n": 24,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_ga",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "ga",
        "ga-population-size": 24,
        "ga-generations": 16,
        "ga-mutation-prob": 0.12,
        "curves-per-n": 12,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 12000,
        "b2-min": 1000,
        "b2-max": 144000,
        "ratio-max": 12
      }
    },
    {
      "type": "validate",
      "label": "val_ga",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_ga.result_file"
        },
        "curves-per-n": 24,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "analyze",
      "label": "analysis_all_methods",
      "args": {
        "input": [
          {
            "$ref": "opt_de.result_file"
          },
          {
            "$ref": "opt_rs.result_file"
          },
          {
            "$ref": "opt_pso.result_file"
          },
          {
            "$ref": "opt_bo.result_file"
          },
          {
            "$ref": "opt_ga.result_file"
          }
        ],
        "group-by": [
          "divisor_size",
          "method"
        ]
      }
    }
  ]
}
