{
  "format": "ecm_run_plan_v1",
  "description": "Тюнинг после трёх полных прогонов для target-digits=20: фокус на RS/GA/PSO, суженное окно B1/B2 и BO в режиме sanity-check",
  "params": {
    "shared": {
      "curve_timeout_sec": 5,
      "opt_curves_per_n": 12,
      "val_curves_per_n": 24
    },
    "search": {
      "b1_min": 1000,
      "b1_max": 12000,
      "b2_min": 1000,
      "b2_max": 144000,
      "ratio_max": 12
    }
  },
  "operations": [
    {
      "type": "generate",
      "label": "dataset_main",
      "args": {
        "target-digits": 20,
        "cofactor-digits": 30,
        "train-count": 20,
        "control-count": 20,
        "seed": 42
      }
    },
    {
      "type": "optimize",
      "label": "opt_de",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "de",
        "de-popsize": 10,
        "de-maxiter": 8,
        "curves-per-n": {
          "$ref": "params.shared.opt_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        },
        "b1-min": {
          "$ref": "params.search.b1_min"
        },
        "b1-max": {
          "$ref": "params.search.b1_max"
        },
        "b2-min": {
          "$ref": "params.search.b2_min"
        },
        "b2-max": {
          "$ref": "params.search.b2_max"
        },
        "ratio-max": {
          "$ref": "params.search.ratio_max"
        }
      }
    },
    {
      "type": "validate",
      "label": "val_de",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_de.result_file"
        },
        "curves-per-n": {
          "$ref": "params.shared.val_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        }
      }
    },
    {
      "type": "optimize",
      "label": "opt_rs",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "rs",
        "rs-budget": 80,
        "curves-per-n": {
          "$ref": "params.shared.opt_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        },
        "b1-min": {
          "$ref": "params.search.b1_min"
        },
        "b1-max": {
          "$ref": "params.search.b1_max"
        },
        "b2-min": {
          "$ref": "params.search.b2_min"
        },
        "b2-max": {
          "$ref": "params.search.b2_max"
        },
        "ratio-max": {
          "$ref": "params.search.ratio_max"
        }
      }
    },
    {
      "type": "validate",
      "label": "val_rs",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_rs.result_file"
        },
        "curves-per-n": {
          "$ref": "params.shared.val_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        }
      }
    },
    {
      "type": "optimize",
      "label": "opt_pso",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "pso",
        "pso-swarm-size": 20,
        "pso-iterations": 14,
        "curves-per-n": {
          "$ref": "params.shared.opt_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        },
        "b1-min": {
          "$ref": "params.search.b1_min"
        },
        "b1-max": {
          "$ref": "params.search.b1_max"
        },
        "b2-min": {
          "$ref": "params.search.b2_min"
        },
        "b2-max": {
          "$ref": "params.search.b2_max"
        },
        "ratio-max": {
          "$ref": "params.search.ratio_max"
        }
      }
    },
    {
      "type": "validate",
      "label": "val_pso",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_pso.result_file"
        },
        "curves-per-n": {
          "$ref": "params.shared.val_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        }
      }
    },
    {
      "type": "optimize",
      "label": "opt_bo",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "bo",
        "bo-initial-samples": 10,
        "bo-iterations": 10,
        "bo-candidate-pool": 1000,
        "curves-per-n": {
          "$ref": "params.shared.opt_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        },
        "b1-min": {
          "$ref": "params.search.b1_min"
        },
        "b1-max": {
          "$ref": "params.search.b1_max"
        },
        "b2-min": {
          "$ref": "params.search.b2_min"
        },
        "b2-max": {
          "$ref": "params.search.b2_max"
        },
        "ratio-max": {
          "$ref": "params.search.ratio_max"
        }
      }
    },
    {
      "type": "validate",
      "label": "val_bo",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_bo.result_file"
        },
        "curves-per-n": {
          "$ref": "params.shared.val_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        }
      }
    },
    {
      "type": "optimize",
      "label": "opt_ga",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "ga",
        "ga-population-size": 24,
        "ga-generations": 16,
        "ga-mutation-prob": 0.12,
        "curves-per-n": {
          "$ref": "params.shared.opt_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        },
        "b1-min": {
          "$ref": "params.search.b1_min"
        },
        "b1-max": {
          "$ref": "params.search.b1_max"
        },
        "b2-min": {
          "$ref": "params.search.b2_min"
        },
        "b2-max": {
          "$ref": "params.search.b2_max"
        },
        "ratio-max": {
          "$ref": "params.search.ratio_max"
        }
      }
    },
    {
      "type": "validate",
      "label": "val_ga",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_ga.result_file"
        },
        "curves-per-n": {
          "$ref": "params.shared.val_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        }
      }
    },
    {
      "type": "analyze",
      "label": "analysis_all_methods",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "group-by": [
          "divisor_size",
          "method"
        ]
      }
    }
  ]
}
