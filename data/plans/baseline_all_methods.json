{
  "format": "ecm_run_plan_v1",
  "description": "Тюнинг после двух полных прогонов: компактное окно B1/B2, повышенные бюджеты и приоритет PSO/GA/DE для нового запуска",
  "operations": [
    {
      "type": "generate",
      "label": "dataset_main",
      "args": {
        "target-digits": 20,
        "cofactor-digits": 30,
        "train-count": 20,
        "control-count": 20,
        "seed": 42
      }
    },
    {
      "type": "optimize",
      "label": "opt_de",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "de",
        "de-popsize": 10,
        "de-maxiter": 10,
        "curves-per-n": 12,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 30000,
        "b2-min": 1000,
        "b2-max": 600000,
        "ratio-max": 20
      }
    },
    {
      "type": "validate",
      "label": "val_de",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_de.result_file"
        },
        "curves-per-n": 24,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_rs",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "rs",
        "rs-budget": 60,
        "curves-per-n": 12,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 30000,
        "b2-min": 1000,
        "b2-max": 600000,
        "ratio-max": 20
      }
    },
    {
      "type": "validate",
      "label": "val_rs",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_rs.result_file"
        },
        "curves-per-n": 24,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_pso",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "pso",
        "pso-swarm-size": 18,
        "pso-iterations": 12,
        "curves-per-n": 12,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 30000,
        "b2-min": 1000,
        "b2-max": 600000,
        "ratio-max": 20
      }
    },
    {
      "type": "validate",
      "label": "val_pso",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_pso.result_file"
        },
        "curves-per-n": 24,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_bo",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "bo",
        "bo-initial-samples": 16,
        "bo-iterations": 22,
        "bo-candidate-pool": 2500,
        "curves-per-n": 12,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 30000,
        "b2-min": 1000,
        "b2-max": 600000,
        "ratio-max": 20
      }
    },
    {
      "type": "validate",
      "label": "val_bo",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_bo.result_file"
        },
        "curves-per-n": 24,
        "curve-timeout-sec": 5
      }
    },
    {
      "type": "optimize",
      "label": "opt_ga",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "method": "ga",
        "ga-population-size": 22,
        "ga-generations": 14,
        "ga-mutation-prob": 0.14,
        "curves-per-n": 12,
        "curve-timeout-sec": 5,
        "b1-min": 1000,
        "b1-max": 30000,
        "b2-min": 1000,
        "b2-max": 600000,
        "ratio-max": 20
      }
    },
    {
      "type": "validate",
      "label": "val_ga",
      "args": {
        "dataset": {
          "$ref": "dataset_main.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_ga.result_file"
        },
        "curves-per-n": 24,
        "curve-timeout-sec": 5
      }
    }
  ]
}
