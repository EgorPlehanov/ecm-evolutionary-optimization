{
  "format": "ecm_run_plan_v1",
  "description": "Один полный прогон по всем методам (de/rs/pso/bo/ga) на одном датасете target-digits=20: generate + optimize + validate + общий analyze.",
  "params": {
    "shared": {
      "curve_timeout_sec": 5,
      "opt_curves_per_n": 12,
      "val_curves_per_n": 24
    },
    "search": {
      "b1_min": 1000,
      "b1_max": 30000,
      "b2_min": 1000,
      "b2_max": 600000,
      "ratio_max": 20
    }
  },
  "operations": [
    {
      "type": "generate",
      "label": "dataset_20_single",
      "args": {
        "target-digits": 20,
        "cofactor-digits": 30,
        "train-count": 20,
        "control-count": 20,
        "seed": 42
      }
    },
    {
      "type": "optimize",
      "label": "opt_de_single",
      "args": {
        "dataset": {
          "$ref": "dataset_20_single.dataset_dir"
        },
        "method": "de",
        "de-popsize": 10,
        "de-maxiter": 10,
        "curves-per-n": {
          "$ref": "params.shared.opt_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        },
        "b1-min": {
          "$ref": "params.search.b1_min"
        },
        "b1-max": {
          "$ref": "params.search.b1_max"
        },
        "b2-min": {
          "$ref": "params.search.b2_min"
        },
        "b2-max": {
          "$ref": "params.search.b2_max"
        },
        "ratio-max": {
          "$ref": "params.search.ratio_max"
        }
      }
    },
    {
      "type": "validate",
      "label": "val_de_single",
      "args": {
        "dataset": {
          "$ref": "dataset_20_single.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_de_single.result_file"
        },
        "curves-per-n": {
          "$ref": "params.shared.val_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        }
      }
    },
    {
      "type": "optimize",
      "label": "opt_rs_single",
      "args": {
        "dataset": {
          "$ref": "dataset_20_single.dataset_dir"
        },
        "method": "rs",
        "rs-budget": 60,
        "curves-per-n": {
          "$ref": "params.shared.opt_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        },
        "b1-min": {
          "$ref": "params.search.b1_min"
        },
        "b1-max": {
          "$ref": "params.search.b1_max"
        },
        "b2-min": {
          "$ref": "params.search.b2_min"
        },
        "b2-max": {
          "$ref": "params.search.b2_max"
        },
        "ratio-max": {
          "$ref": "params.search.ratio_max"
        }
      }
    },
    {
      "type": "validate",
      "label": "val_rs_single",
      "args": {
        "dataset": {
          "$ref": "dataset_20_single.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_rs_single.result_file"
        },
        "curves-per-n": {
          "$ref": "params.shared.val_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        }
      }
    },
    {
      "type": "optimize",
      "label": "opt_pso_single",
      "args": {
        "dataset": {
          "$ref": "dataset_20_single.dataset_dir"
        },
        "method": "pso",
        "pso-swarm-size": 18,
        "pso-iterations": 12,
        "curves-per-n": {
          "$ref": "params.shared.opt_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        },
        "b1-min": {
          "$ref": "params.search.b1_min"
        },
        "b1-max": {
          "$ref": "params.search.b1_max"
        },
        "b2-min": {
          "$ref": "params.search.b2_min"
        },
        "b2-max": {
          "$ref": "params.search.b2_max"
        },
        "ratio-max": {
          "$ref": "params.search.ratio_max"
        }
      }
    },
    {
      "type": "validate",
      "label": "val_pso_single",
      "args": {
        "dataset": {
          "$ref": "dataset_20_single.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_pso_single.result_file"
        },
        "curves-per-n": {
          "$ref": "params.shared.val_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        }
      }
    },
    {
      "type": "optimize",
      "label": "opt_bo_single",
      "args": {
        "dataset": {
          "$ref": "dataset_20_single.dataset_dir"
        },
        "method": "bo",
        "bo-initial-samples": 16,
        "bo-iterations": 22,
        "bo-candidate-pool": 2500,
        "curves-per-n": {
          "$ref": "params.shared.opt_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        },
        "b1-min": {
          "$ref": "params.search.b1_min"
        },
        "b1-max": {
          "$ref": "params.search.b1_max"
        },
        "b2-min": {
          "$ref": "params.search.b2_min"
        },
        "b2-max": {
          "$ref": "params.search.b2_max"
        },
        "ratio-max": {
          "$ref": "params.search.ratio_max"
        }
      }
    },
    {
      "type": "validate",
      "label": "val_bo_single",
      "args": {
        "dataset": {
          "$ref": "dataset_20_single.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_bo_single.result_file"
        },
        "curves-per-n": {
          "$ref": "params.shared.val_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        }
      }
    },
    {
      "type": "optimize",
      "label": "opt_ga_single",
      "args": {
        "dataset": {
          "$ref": "dataset_20_single.dataset_dir"
        },
        "method": "ga",
        "ga-population-size": 22,
        "ga-generations": 14,
        "ga-mutation-prob": 0.14,
        "curves-per-n": {
          "$ref": "params.shared.opt_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        },
        "b1-min": {
          "$ref": "params.search.b1_min"
        },
        "b1-max": {
          "$ref": "params.search.b1_max"
        },
        "b2-min": {
          "$ref": "params.search.b2_min"
        },
        "b2-max": {
          "$ref": "params.search.b2_max"
        },
        "ratio-max": {
          "$ref": "params.search.ratio_max"
        }
      }
    },
    {
      "type": "validate",
      "label": "val_ga_single",
      "args": {
        "dataset": {
          "$ref": "dataset_20_single.dataset_dir"
        },
        "opt-result-file": {
          "$ref": "opt_ga_single.result_file"
        },
        "curves-per-n": {
          "$ref": "params.shared.val_curves_per_n"
        },
        "curve-timeout-sec": {
          "$ref": "params.shared.curve_timeout_sec"
        }
      }
    },
    {
      "type": "analyze",
      "label": "analysis_single_dataset_all_methods",
      "args": {
        "dataset": {
          "$ref": "dataset_20_single.dataset_dir"
        },
        "group-by": [
          "divisor_size",
          "method"
        ]
      }
    }
  ]
}
