{
  "format": "ecm_run_plan_v1",
  "description": "Тюнинг-план для target-digits=20: мульти-seed прогон (17/2718/31415) со вложенным циклом по методам de/rs/pso/bo/ga и общим анализом.",
  "params": {
    "search": {
      "b1-min": 1000,
      "b1-max": 12000,
      "b2-min": 1000,
      "b2-max": 144000,
      "ratio-max": 12
    },
    "method_list": [
      "de",
      "rs",
      "pso",
      "bo",
      "ga"
    ],
    "method_opt": {
      "de": {
        "de-popsize": 10,
        "de-maxiter": 8
      },
      "rs": {
        "rs-budget": 80
      },
      "pso": {
        "pso-swarm-size": 20,
        "pso-iterations": 14
      },
      "bo": {
        "bo-initial-samples": 10,
        "bo-iterations": 10,
        "bo-candidate-pool": 1000
      },
      "ga": {
        "ga-population-size": 24,
        "ga-generations": 16,
        "ga-mutation-prob": 0.12
      }
    },
    "seeds": [
      17,
      2718,
      31415
    ],
    "shared_opt_args": {
      "curves-per-n": 12,
      "curve-timeout-sec": 5
    },
    "shared_val_args": {
      "curves-per-n": 24,
      "curve-timeout-sec": 5
    }
  },
  "operations": [
    {
      "label": "seed_runs",
      "repeat": {
        "as": "seed_iter",
        "values": {
          "seed": "$ref:params.seeds"
        }
      },
      "operations": [
        {
          "type": "generate",
          "label": "dataset_main_{{seed_iter.seed}}",
          "args": {
            "target-digits": 20,
            "cofactor-digits": 30,
            "train-count": 20,
            "control-count": 20,
            "seed": "$ref:seed_iter.seed"
          }
        },
        {
          "repeat": {
            "as": "method_iter",
            "values": {
              "method": "$ref:params.method_list"
            }
          },
          "operations": [
            {
              "type": "optimize",
              "label": "opt_{{method_iter.method}}_{{seed_iter.seed}}",
              "args": {
                "dataset": "$ref:dataset_main_{{seed_iter.seed}}.dataset_dir",
                "method": "$ref:method_iter.method",
                "seed": "$ref:seed_iter.seed",
                "$spread_ref": [
                  "params.shared_opt_args",
                  "params.method_opt.{{method_iter.method}}",
                  "params.search"
                ]
              }
            },
            {
              "type": "validate",
              "label": "val_{{method_iter.method}}_{{seed_iter.seed}}",
              "args": {
                "dataset": "$ref:dataset_main_{{seed_iter.seed}}.dataset_dir",
                "opt-result-file": "$ref:opt_{{method_iter.method}}_{{seed_iter.seed}}.result_file",
                "seed": "$ref:seed_iter.seed",
                "$spread_ref": "params.shared_val_args"
              }
            }
          ]
        }
      ]
    },
    {
      "type": "analyze",
      "label": "analysis_all_methods_multi_seed",
      "args": {
        "dataset": {
          "$map_ref": {
            "items": "$ref:seed_runs.values.seed",
            "template": "dataset_main_{{item}}.dataset_dir"
          }
        },
        "group-by": [
          "divisor_size",
          "method"
        ]
      }
    }
  ]
}
